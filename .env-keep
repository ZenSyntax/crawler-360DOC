# 示例占位：推荐复制本文件为 .env 后填入真实值；亦可重命名去掉 -keep 后缀得到 .env（会移除工作区内的本模板文件）。
# 真实 .env 已被 .gitignore 忽略，请勿将含密码的文件提交到仓库。

# 360doc 账号（wc-essay.py）
DOC360_USER=your_360doc_login
DOC360_PASS=your_plain_password

# 随笔抓取请求频控（毫秒，须同时设置且 MIN≤MAX；缺省或无效时用 2000–5000）
DOC360_MIN_TIME=5000
DOC360_MAX_TIME=10000

# 并发抓取线程数上限（须为正整数；缺省或无效时用 50）
DOC360_MAX_WORKERS=50

# 邮件告警（未配置收件人时仅控制台日志，程序仍继续）
# 告警收件人
DOC360_ALERT_TO=alert_recipient@example.com
# 发件人（通常与 SMTP 登录账号一致）
DOC360_SENDER=smtp_login@example.com
# SMTP 密码或授权码（QQ 为授权码；Gmail/Outlook 多为应用专用密码）
DOC360_KEY=your_smtp_app_password_or_secret
DOC360_SMTP_HOST=smtp.example.com
DOC360_SMTP_PORT=465
# QQ 465 SSL 时留空；587 等需 STARTTLS 时可设为 1 / true / yes / on
DOC360_SMTP_STARTTLS=
